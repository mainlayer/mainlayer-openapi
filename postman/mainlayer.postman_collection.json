    "_postman_id": "ml-openapi-v1-2026",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.mainlayer.xyz",
      "type": "string",
      "description": "Mainlayer API base URL."
    },
    {
      "key": "apiKey",
      "value": "ml_live_sk_YOUR_KEY_HERE",
      "type": "string",
      "description": "Your Mainlayer API key. Get one from POST /api-keys or the dashboard."
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string",
      "description": "Short-lived JWT populated automatically by the Login request test script."
    },
    {
      "key": "vendorId",
      "value": "ven_01HX4K9ZRMN8QWTBGX2V3F5P7",
      "type": "string"
    },
    {
      "key": "resourceId",
      "value": "res_01HX4K9ZRMN8QWTBGX2V3F5P7",
      "type": "string"
    },
    {
      "key": "paymentId",
      "value": "pay_01HX4K9ZRMN8QWTBGX2V3F5PA",
      "type": "string"
    },
    {
      "key": "subscriptionId",
      "value": "sub_01HX4K9ZRMN8QWTBGX2V3F5PC",
      "type": "string"
    },
    {
      "key": "apiKeyId",
      "value": "key_01HX4K9ZRMN8QWTBGX2V3F5PD",
      "type": "string"
    },
    {
      "key": "invoiceId",
      "value": "inv_01HX4K9ZRMN8QWTBGX2V3F5PE",
      "type": "string"
    },
    {
      "key": "webhookId",
      "value": "wh_01HX4K9ZRMN8QWTBGX2V3F5PG",
      "type": "string"

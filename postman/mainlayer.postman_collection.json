            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"gpt-summarizer-v2\",\n  \"type\": \"api\",\n  \"price\": 0.05,\n  \"fee_model\": \"per_call\",\n  \"description\": \"Summarizes any text into 3 bullet points. Ideal for AI pipelines that need concise digests.\",\n  \"callback_url\": \"https://api.example.com/mainlayer/callback\",\n  \"tags\": [\"nlp\", \"summarization\", \"gpt\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Register a new monetized resource."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [

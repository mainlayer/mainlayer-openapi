              "raw": "{\n  \"price\": 0.08,\n  \"description\": \"Updated: Summarizes any text into 3 bullet points. Now 40% faster.\",\n  \"tags\": [\"nlp\", \"summarization\", \"gpt\", \"v2\"]\n}",
              "options": { "raw": { "language": "json" } }
